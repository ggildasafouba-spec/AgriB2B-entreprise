# Variables d'environnement du backend

# Base de données PostgreSQL
DATABASE_URL=postgresql://agromarket:agromarket@postgres:5432/agromarket

# Redis Cache
REDIS_URL=redis://localhost:16379

# JWT Secret - À changer en production !
JWT_SECRET=dev_jwt_secret_key_agromarket_2026_change_me

# Serveur Backend
BACKEND_PORT=4000
NODE_ENV=development

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000

# Base API URL (utilisée par le frontend)
BACKEND_API_URL=http://localhost:4000

# NotchPay - Paiements Mobile Money (MTN MoMo, Orange Money)
# Récupérer sur business.notchpay.co > Settings > API Keys
NOTCHPAY_PUBLIC_KEY=your_notchpay_public_key_here
# Hash key pour vérifier les signatures des webhooks (Settings > Webhooks)
NOTCHPAY_HASH_KEY=your_notchpay_hash_key_here
